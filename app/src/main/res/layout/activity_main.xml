<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/iv_main_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="#000000" />

    <LinearLayout
        android:id="@+id/layout_main_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingTop="36dp"
        android:visibility="visible"
        android:background="#00000000">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#55000000"
            android:gravity="top"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingBottom="8dp">

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@+id/btn_now_playing" android:layout_width="match_parent" android:layout_height="48dp" android:text="Now Playing" android:textColor="#FFFFFF" android:background="#00000000" android:gravity="left|center_vertical" android:paddingLeft="15dp" android:textSize="18sp" android:focusable="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="48dp" android:text="〉" android:textColor="#888888" android:gravity="center_vertical" android:layout_gravity="right" android:paddingRight="15dp" android:textSize="16sp" android:focusable="false" android:clickable="false"/>
            </FrameLayout>

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@+id/btn_play" android:layout_width="match_parent" android:layout_height="48dp" android:text="Music" android:textColor="#FFFFFF" android:background="#00000000" android:gravity="left|center_vertical" android:paddingLeft="15dp" android:textSize="18sp" android:focusable="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="48dp" android:text="〉" android:textColor="#888888" android:gravity="center_vertical" android:layout_gravity="right" android:paddingRight="15dp" android:textSize="16sp" android:focusable="false" android:clickable="false"/>
            </FrameLayout>

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@+id/btn_bluetooth" android:layout_width="match_parent" android:layout_height="48dp" android:text="Bluetooth" android:textColor="#FFFFFF" android:background="#00000000" android:gravity="left|center_vertical" android:paddingLeft="15dp" android:textSize="18sp" android:focusable="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="48dp" android:text="〉" android:textColor="#888888" android:gravity="center_vertical" android:layout_gravity="right" android:paddingRight="15dp" android:textSize="16sp" android:focusable="false" android:clickable="false"/>
            </FrameLayout>

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@+id/btn_settings" android:layout_width="match_parent" android:layout_height="48dp" android:text="Settings" android:textColor="#FFFFFF" android:background="#00000000" android:gravity="left|center_vertical" android:paddingLeft="15dp" android:textSize="18sp" android:focusable="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="48dp" android:text="〉" android:textColor="#888888" android:gravity="center_vertical" android:layout_gravity="right" android:paddingRight="15dp" android:textSize="16sp" android:focusable="false" android:clickable="false"/>
            </FrameLayout>

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@+id/btn_radio" android:layout_width="match_parent" android:layout_height="48dp" android:text="FM Radio" android:textColor="#FFFFFF" android:background="#00000000" android:gravity="left|center_vertical" android:paddingLeft="15dp" android:textSize="18sp" android:focusable="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="48dp" android:text="〉" android:textColor="#888888" android:gravity="center_vertical" android:layout_gravity="right" android:paddingRight="15dp" android:textSize="16sp" android:focusable="false" android:clickable="false"/>
            </FrameLayout>

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@+id/btn_webserver" android:layout_width="match_parent" android:layout_height="48dp" android:text="PC Upload" android:textColor="#FFFFFF" android:background="#00000000" android:gravity="left|center_vertical" android:paddingLeft="15dp" android:textSize="18sp" android:focusable="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="48dp" android:text="〉" android:textColor="#888888" android:gravity="center_vertical" android:layout_gravity="right" android:paddingRight="15dp" android:textSize="16sp" android:focusable="false" android:clickable="false"/>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#00000000"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="5dp">

            <ImageView
                android:id="@+id/iv_menu_preview"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_media_play"/>

            <TextView
                android:id="@+id/tv_menu_preview_title"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_menu_preview_artist"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_browser_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:orientation="horizontal"
        android:paddingTop="36dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tv_browser_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:singleLine="true"
                android:text="Path: /Music"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/container_browser_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false" />
            </ScrollView>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/frame_browser_cover"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_browser_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/default_album" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_settings_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:background="#66000000"
        android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="SETTINGS" android:textColor="#BBFFFFFF" android:textSize="16sp" android:textStyle="bold" android:singleLine="true" android:layout_marginBottom="6dp"/>
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
            <LinearLayout android:id="@+id/container_settings_items" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_bluetooth_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:background="#66000000"
        android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BLUETOOTH SCAN" android:textColor="#BBFFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_scan_bt" android:layout_width="match_parent" android:layout_height="40dp" android:text="🔍 Scan Devices" android:textColor="#FFFFFF" android:textSize="16sp" android:background="#15FFFFFF" android:focusable="true"/>
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:layout_marginTop="5dp">
            <LinearLayout android:id="@+id/container_bt_items" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_wifi_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:background="#66000000"
        android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="WI-FI NETWORKS" android:textColor="#BBFFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_scan_wifi" android:layout_width="match_parent" android:layout_height="40dp" android:text="🔍 Scan Networks" android:textColor="#FFFFFF" android:textSize="16sp" android:background="#15FFFFFF" android:focusable="true"/>
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:layout_marginTop="5dp">
            <LinearLayout android:id="@+id/container_wifi_items" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_wifi_keyboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="36dp"
        android:padding="15dp"
        android:background="#66000000"
        android:visibility="gone">
        <TextView android:id="@+id/tv_keyboard_ssid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Target: My_Home_Wifi" android:textColor="#BBFFFFFF" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_keyboard_input" android:layout_width="match_parent" android:layout_height="40dp" android:text="" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:gravity="center" android:background="#222222" android:layout_marginTop="10dp" android:layout_marginBottom="15dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
            <TextView android:id="@+id/tv_key_pprev" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="a" android:textColor="#555555" android:textSize="14sp" android:layout_marginRight="12dp"/>
            <TextView android:id="@+id/tv_key_prev" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="b" android:textColor="#AAAAAA" android:textSize="20sp" android:layout_marginRight="12dp"/>
            <TextView android:id="@+id/tv_key_current" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="c" android:textColor="#FFFFFF" android:textSize="36sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_key_next" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="d" android:textColor="#AAAAAA" android:textSize="20sp" android:layout_marginLeft="12dp"/>
            <TextView android:id="@+id/tv_key_nnext" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="e" android:textColor="#555555" android:textSize="14sp" android:layout_marginLeft="12dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_music_quiz_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:background="@drawable/quiz_bg_gradient"
        android:visibility="gone">

        <RelativeLayout android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tv_quiz_round" android:layout_width="34dp" android:layout_height="34dp" android:layout_alignParentLeft="true" android:background="@drawable/quiz_round_badge" android:gravity="center" android:text="1" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_quiz_lives" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:text="♥ ♥ ♥" android:textColor="#FF6B6B" android:textSize="18sp" android:textStyle="bold"/>
        </RelativeLayout>

        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/quiz_question_card" android:padding="10dp" android:layout_marginBottom="12dp">
            <com.themoon.y1.views.SquareImageView android:id="@+id/iv_quiz_cover" android:layout_width="90dp" android:layout_height="90dp" android:layout_gravity="center_horizontal" android:scaleType="centerCrop" android:src="@drawable/default_album" android:background="#DDDDDD"/>
            <TextView android:id="@+id/tv_quiz_prompt" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="What song is playing?" android:textColor="#173350" android:textSize="17sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="8dp"/>
        </LinearLayout>

        <ProgressBar android:id="@+id/pb_quiz_timer" style="?android:attr/progressBarStyleHorizontal" android:progressDrawable="@drawable/progress_bar_ipod" android:layout_width="match_parent" android:layout_height="10dp" android:max="1000" android:progress="1000" android:layout_marginBottom="14dp"/>

        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <LinearLayout android:id="@+id/container_quiz_items" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
        </ScrollView>

        <TextView android:id="@+id/tv_quiz_score" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="$0" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="10dp"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_player_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFFFF"
        android:visibility="gone">
        <ImageView android:id="@+id/iv_player_bg_blur" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="#111111" android:visibility="gone"/>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="top" android:paddingTop="6dp" android:paddingLeft="15dp" android:paddingRight="15dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerHorizontal="true" android:text="Now Playing" android:textColor="#3C3C43" android:textSize="14sp" android:textStyle="bold" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/iv_player_shuffle_status"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/iv_player_repeat_status"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone" />
            </LinearLayout>
        </RelativeLayout>

        <!-- 🚀 커버+텍스트 뭉치를 사용 가능한 세로 공간 안에서 정중앙 배치! -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center_vertical" android:paddingTop="16dp" android:paddingBottom="46dp" android:paddingLeft="14dp" android:paddingRight="14dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginRight="14dp">
                    <FrameLayout android:id="@+id/frame_album_art" android:layout_width="187dp" android:layout_height="187dp"
                        android:rotationY="18">
                        <com.themoon.y1.views.SquareImageView android:id="@+id/iv_album_art" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/default_album" android:background="#DDDDDD" />
                        <ImageView android:id="@+id/iv_pause_overlay" android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="center" android:src="@android:drawable/ic_media_pause" android:visibility="gone" />
                    </FrameLayout>
                    <!-- 🚀 [신규 추가] 아래로 살짝 비치는 반사 효과 (iPod 스타일) -->
                    <FrameLayout android:id="@+id/frame_album_reflection" android:layout_width="187dp" android:layout_height="28dp" android:layout_marginTop="1dp"
                        android:rotationY="18">
                        <ImageView android:id="@+id/iv_album_reflection" android:layout_width="187dp" android:layout_height="187dp" android:layout_gravity="top" android:scaleY="-1" android:scaleType="centerCrop" android:alpha="0.30" android:src="@drawable/default_album" />
                        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/reflection_fade_gradient" />
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tv_player_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Title" android:textColor="#000000" android:textSize="19sp" android:textStyle="bold" android:gravity="left" android:singleLine="true" android:ellipsize="end" />
                    <TextView android:id="@+id/tv_player_artist" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Artist" android:textColor="#3C3C43" android:textSize="15sp" android:gravity="left" android:layout_marginTop="4dp" android:singleLine="true" android:ellipsize="end" />
                    <TextView android:id="@+id/tv_player_album" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Album" android:textColor="#3C3C43" android:textSize="15sp" android:gravity="left" android:singleLine="true" android:ellipsize="end" />
                    <TextView android:id="@+id/tv_player_track_count" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1 of 1" android:textColor="#8E8E93" android:textSize="13sp" android:gravity="left" android:layout_marginTop="10dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 🚀 [수정] 진행바를 화면 맨 아래로, 좌우 여백을 줘서 조금 짧게, 더 두껍게. 시간 글씨는 굵고 크게! -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:orientation="horizontal" android:gravity="center_vertical" android:paddingLeft="26dp" android:paddingRight="26dp" android:paddingBottom="14dp">
            <TextView android:id="@+id/tv_player_time_current" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0:00" android:textColor="#000000" android:textStyle="bold" android:textSize="16sp" android:layout_marginRight="10dp"/>
            <ProgressBar android:id="@+id/player_progress" style="?android:attr/progressBarStyleHorizontal" android:progressDrawable="@drawable/progress_bar_now_playing" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:max="100" android:progress="0"/>
            <TextView android:id="@+id/tv_player_time_total" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-0:00" android:textColor="#000000" android:textStyle="bold" android:textSize="16sp" android:layout_marginLeft="10dp"/>
        </LinearLayout>
    </FrameLayout>

    <RelativeLayout
        android:id="@+id/layout_status_bar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:background="#00000000">

        <TextView
            android:id="@+id/tv_status_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:text="12:00 AM"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#FF000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView android:id="@+id/iv_status_headphone" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_headphone" android:visibility="gone" android:layout_marginRight="8dp"/>
            <ImageView android:id="@+id/iv_status_wifi" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_wifi" android:visibility="gone" android:layout_marginRight="8dp"/>
            <ImageView android:id="@+id/iv_status_bluetooth" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_bluetooth" android:visibility="gone" android:layout_marginRight="12dp"/>
            <TextView android:id="@+id/tv_status_battery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:shadowColor="#FF000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="3"/>
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layout_volume_overlay"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Volume" android:textColor="#FFFFFF" android:textSize="16sp" android:layout_marginBottom="10dp"/>
        <ProgressBar android:id="@+id/volume_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="15dp" android:max="15" android:progress="10"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_brightness_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:paddingTop="36dp"
        android:background="#66000000"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DISPLAY BRIGHTNESS" android:textColor="#BBFFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="30dp"/>
        <ProgressBar android:id="@+id/pb_brightness" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="20dp" android:max="255" android:layout_marginBottom="15dp"/>
        <TextView android:id="@+id/tv_brightness_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_storage_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:paddingTop="36dp"
        android:background="#66000000"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" text="STORAGE INFO" android:textColor="#BBFFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="30dp"/>
        <ProgressBar android:id="@+id/pb_storage" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="20dp" android:layout_marginBottom="15dp"/>
        <TextView android:id="@+id/tv_storage_details" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Used: 0MB / Total: 0MB" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Press [Back] to return." android:textColor="#888888" android:textSize="14sp" android:layout_marginTop="30dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_webserver_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:paddingTop="36dp"
        android:background="#66000000"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WIRELESS PC UPLOAD" android:textColor="#BBFFFFFF" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="40dp"/>
        <TextView android:id="@+id/tv_server_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔴 SERVER STOPPED" android:textColor="#FF5555" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="10dp"/>
        <TextView android:id="@+id/tv_server_ip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="http://---.---.---.---:8080" android:textColor="#888888" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="50dp"/>
        <Button android:id="@+id/btn_server_toggle" android:layout_width="350dp" android:layout_height="wrap_content" android:text="START SERVER" android:textSize="22sp" android:textColor="#FFFFFF" android:background="#00000000" android:padding="15dp" android:layout_marginBottom="30dp" android:focusable="true"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Enter the above address in your PC browser.\nPress [Back] to return." android:textColor="#888888" android:textSize="16sp" android:gravity="center"/>
    </LinearLayout>
</FrameLayout>